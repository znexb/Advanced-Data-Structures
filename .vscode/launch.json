{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug main.exe",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/assignments/03/median/debug.exe",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,

            "MIMode": "gdb",
            "miDebuggerPath": "gdb",

            "externalConsole": false,

            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}